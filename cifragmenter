#!/usr/bin/env bash
set -euo pipefail

# ====== настройки проекта ======
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${CIFRAGMENTER_VENV:-$PROJECT_ROOT/.venv}"

PY="$VENV_DIR/bin/python"
PIP="$VENV_DIR/bin/pip"

OPENBABEL_PREFIX="$PROJECT_ROOT/openbabel"
OB_BUILD_DIR="$PROJECT_ROOT/OBbuild"
OB_SRC_DIR="$PROJECT_ROOT/openbabel-openbabel-3-1-1"

cmd="${1:-}"
shift || true

die() { echo "ERROR: $*" >&2; exit 2; }

ensure_venv() {
  if [[ ! -x "$PY" ]]; then
    die "venv не найден. Сначала: ./cifragmenter setup"
  fi
}

py_mm() {
  "$PY" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")'
}

ob_site_packages() {
  local mm
  mm="$(py_mm)"
  echo "$OPENBABEL_PREFIX/lib/python${mm}/site-packages"
}

apply_pythonpath() {
  local sp
  sp="$(ob_site_packages)"
  if [[ -d "$sp" ]]; then
    export PYTHONPATH="$sp:${PYTHONPATH:-}"
  fi
}

case "$cmd" in
  setup)
    cd "$PROJECT_ROOT"

    command -v python3.12 >/dev/null 2>&1 || die "python3.12 не найден в системе"
    if [[ ! -d "$VENV_DIR" ]]; then
      python3.12 -m venv "$VENV_DIR"
    fi

    "$PY" -m pip install --upgrade pip

    "$PIP" install numpy scipy matplotlib
    "$PIP" install pymatgen
    "$PIP" install cmake
    "$PIP" install rdkit

    [[ -d "$OB_SRC_DIR" ]] || die "Нет исходников OpenBabel: $OB_SRC_DIR"

    mkdir -p "$OB_BUILD_DIR"
    cd "$OB_BUILD_DIR"

    PYEXE="$PY"
    PYINC="$("$PY" -c 'import sysconfig; print(sysconfig.get_path("include"))')"
    PYLIB="$("$PY" -c 'import sysconfig, os; print(os.path.join(sysconfig.get_config_var("LIBDIR"), sysconfig.get_config_var("LDLIBRARY")))')"

    unset CONDA_PREFIX CONDA_DEFAULT_ENV CONDA_PYTHON_EXE _CE_CONDA _CE_M
    "$PY" -m cmake \
  -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
  -DPYTHON_BINDINGS=ON \
  -DRUN_SWIG=ON \
  -DBUILD_TESTING=OFF \
  -DPython3_EXECUTABLE="$PY" \
  -DPython3_ROOT_DIR="$(dirname "$(dirname "$PY")")" \
  -DPython3_FIND_STRATEGY=LOCATION \
  -DPython3_FIND_VIRTUALENV=ONLY \
  -DCMAKE_INSTALL_PREFIX="$OPENBABEL_PREFIX" \
  "$OB_SRC_DIR"

  	"$PIP" install -U pip setuptools wheel 

    make -j"$(getconf _NPROCESSORS_ONLN 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4)"
    make install

    cd "$PROJECT_ROOT"

    "$PIP" install openbabel

    SP="$(ob_site_packages)"
    cat > "$PROJECT_ROOT/.cifragmenter.env" <<EOF
# autogenerated by ./cifragmenter setup
export PYTHONPATH="$SP:\${PYTHONPATH:-}"

	"$PIP" install -e "$PROJECT_ROOT"


EOF

    echo "OK"
    echo "OpenBabel установлен в: $OPENBABEL_PREFIX"
    echo "PYTHONPATH будет добавлен: $SP"
    echo "Запуск: ./cifragmenter run <путь_до_файла>"
    ;;

  shell)
    ensure_venv
    echo "Активируй окружение:"
    echo "  source \"$VENV_DIR/bin/activate\""
    if [[ -f "$PROJECT_ROOT/.cifragmenter.env" ]]; then
      echo "Подключи PYTHONPATH:"
      echo "  source \"$PROJECT_ROOT/.cifragmenter.env\""
    fi
    ;;

  run)
    ensure_venv
    [[ -f "$PROJECT_ROOT/.cifragmenter.env" ]] && source "$PROJECT_ROOT/.cifragmenter.env"
    apply_pythonpath
    exec "$PY" -m cifragmenter.cli "$@"
    ;;

  exec)
    ensure_venv
    [[ -f "$PROJECT_ROOT/.cifragmenter.env" ]] && source "$PROJECT_ROOT/.cifragmenter.env"
    apply_pythonpath
    exec "$PY" "$@"
    ;;

  ""|-h|--help|help)
    cat <<'EOF'
CiFragmenter

Команды:
  ./cifragmenter setup
  ./cifragmenter shell
  ./cifragmenter run <input_file> [--log-level INFO]
  ./cifragmenter exec <python_args...>

Ожидается папка с исходниками OpenBabel:
  ./openbabel-openbabel-3-1-1

Переменные:
  CIFRAGMENTER_VENV=...   (изменить путь к venv)
EOF
    ;;

  *)
    die "Неизвестная команда: $cmd (см. ./cifragmenter --help)"
    ;;
esac

